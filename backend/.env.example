# =============================================================================
# EcoMind-AI Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment.
#
# SECURITY WARNING:
# - NEVER commit .env files to version control
# - All secrets MUST be unique per environment
# - Use strong, randomly generated values for all secrets
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=EcoMind-AI
APP_VERSION=1.0.0
DEBUG=false

# Environment: development | staging | production
# CRITICAL: Set to 'production' in production to enable security validations
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
TCP_GATEWAY_PORT=9999

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecomind
POSTGRES_USER=ecomind

# SECURITY: Generate strong password with: openssl rand -base64 24
POSTGRES_PASSWORD=

# -----------------------------------------------------------------------------
# TDengine Time-Series Database
# -----------------------------------------------------------------------------
TDENGINE_HOST=tdengine
TDENGINE_PORT=6030
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=ecomind

# =============================================================================
# CRITICAL SECURITY SETTINGS
# =============================================================================
# These values MUST be changed in production. The application will refuse to
# start in production mode with default/weak secrets.

# -----------------------------------------------------------------------------
# JWT Authentication Secret
# -----------------------------------------------------------------------------
# Requirements:
# - Minimum 32 characters
# - Must be unique per environment
# - Generate with: openssl rand -base64 48
#
# Example: JWT_SECRET=K8mHxPqL2nW9vR4tY7uI0oA3sD6fG1hJ5kM8bN2cX4zQ7wE0rT3yU6iO9pA2sD5f
JWT_SECRET=

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# -----------------------------------------------------------------------------
# SM4 Encryption Key (国密算法)
# -----------------------------------------------------------------------------
# Requirements:
# - Exactly 32 hexadecimal characters (16 bytes)
# - Must be unique per environment
# - Generate with: openssl rand -hex 16
#
# Example: SM4_KEY=a1b2c3d4e5f6789012345678abcdef90
SM4_KEY=

# =============================================================================
# CORS Configuration
# =============================================================================
# For production, specify exact allowed origins (comma-separated)
# Example: ALLOWED_ORIGINS=https://app.ecomind.com,https://www.ecomind.com
# WARNING: Never use "*" in production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# AI Model Settings
# -----------------------------------------------------------------------------
ANOMALY_DETECTION_ENABLED=true
ANOMALY_THRESHOLD=0.85

# -----------------------------------------------------------------------------
# Spark LLM (讯飞星火大模型) - AI智能解析和报告生成
# -----------------------------------------------------------------------------
# 用于自检报告AI智能解析和AI运维报告生成
# 获取地址: https://console.xfyun.cn/services/bm35
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=

# -----------------------------------------------------------------------------
# Baidu OCR (百度文字识别) - 自检报告表格识别
# -----------------------------------------------------------------------------
# 用于识别PDF/图片检测报告中的表格数据
# 获取地址: https://console.bce.baidu.com/ai/#/ai/ocr/overview/index
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# -----------------------------------------------------------------------------
# Gateway Configuration
# -----------------------------------------------------------------------------
# GATEWAY_API_KEY=your_gateway_api_key_here
# CLOUDBASE_API_URL=https://your-cloudbase-url.run.tcloudbase.com

# -----------------------------------------------------------------------------
# Superadmin Initialization (one-time setup)
# -----------------------------------------------------------------------------
# INIT_SECRET=your_init_secret_here
# SUPERADMIN_USERNAME=admin
# SUPERADMIN_EMAIL=admin@example.com
# SUPERADMIN_PASSWORD=your_secure_password_here

# =============================================================================
# Quick Setup Commands
# =============================================================================
# Generate all required secrets:
#
#   # JWT Secret (48+ characters)
#   openssl rand -base64 48
#
#   # SM4 Key (32 hex characters)
#   openssl rand -hex 16
#
#   # PostgreSQL Password
#   openssl rand -base64 24
#
# =============================================================================