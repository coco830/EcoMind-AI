# Application Environment Configuration Example
# Copy this file to .env and update the values for your environment

# Application Settings
APP_NAME=EcoMind-AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Server Configuration
HOST=0.0.0.0
PORT=8000
TCP_GATEWAY_PORT=9999

# PostgreSQL Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecomind
POSTGRES_USER=ecomind
POSTGRES_PASSWORD=your-secure-password-here

# TDengine Time-Series Database
TDENGINE_HOST=tdengine
TDENGINE_PORT=6030
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata
TDENGINE_DATABASE=ecomind

# Security - MUST CHANGE IN PRODUCTION!
JWT_SECRET=your-very-long-random-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# SM4 Encryption Key (16 bytes hex)
SM4_KEY=change-this-16-byte-hex-key-now

# CORS Configuration
# For production, set specific origins (comma-separated)
# Example: ALLOWED_ORIGINS=https://app.ecomind.com,https://www.ecomind.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# AI Model Settings
ANOMALY_DETECTION_ENABLED=true
ANOMALY_THRESHOLD=0.85