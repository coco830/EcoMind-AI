{
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "version": "2.0",
  "envId": "yueen-huanbao-1gqfjr5s41e61180",
  "framework": {
    "name": "ecomind-ai",
    "plugins": {
      "server": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "ecomind-ai",
          "servicePath": "/",
          "uploadType": "image",
          "containerPort": 8000,
          "cpu": 1,
          "mem": 2,
          "minNum": 1,
          "maxNum": 5,
          "policyType": "cpu",
          "policyThreshold": 60,
          "dockerfilePath": "./Dockerfile.cloudbase",
          "buildDir": "."
        }
      }
    }
  }
}
