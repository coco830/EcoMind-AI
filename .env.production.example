# EcoMind-AI 生产环境配置示例
# 复制此文件为 .env 并填入实际值
# cp .env.production.example .env

# ============================================
# 数据库配置
# ============================================

# PostgreSQL (使用强密码)
# 生成命令: openssl rand -base64 24
POSTGRES_PASSWORD=your_strong_password_here

# TDengine (如需修改默认密码)
TDENGINE_PASSWORD=taosdata

# Pollutant code alias mapping (for non-standard device codes)
# Preferred JSON format:
# POLLUTANT_CODE_ALIASES={"b01":"w00000","f01":"w00000"}
# Or simple pairs format:
# POLLUTANT_CODE_ALIASES=b01=w00000,f01=w00000
POLLUTANT_CODE_ALIASES={"b01":"w00000"}

# ============================================
# 安全密钥 (必须配置)
# ============================================

# JWT 签名密钥 (至少 32 字符)
# 生成命令: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# SM4 加密密钥 (32 位十六进制)
# 生成命令: openssl rand -hex 16
SM4_KEY=your_32_hex_characters_sm4_key

# ============================================
# CORS 跨域配置 (重要!)
# ============================================
# 添加您的前端域名，多个域名用逗号分隔
# 示例: https://xxx.tcloudbaseapp.com,https://your-domain.com

ALLOWED_ORIGINS=https://your-cloudbase-site.tcloudbaseapp.com,https://your-custom-domain.com

# ============================================
# AI 服务 (讯飞星火大模型 - Spark Max)
# ============================================

SPARK_APP_ID=your_spark_app_id
SPARK_API_KEY=your_spark_api_key
SPARK_API_SECRET=your_spark_api_secret
# SPARK_API_URL=wss://spark-api.xf-yun.com/v3.5/chat
# SPARK_DOMAIN=generalv3.5

# ============================================
# 腾讯云短信服务 (可选)
# ============================================

TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=

# ============================================
# OpenClaw Webhook 主动推送 (可选)
# ============================================
# 启用后，告警创建将主动推送到 OpenClaw Gateway hooks 端点

OPENCLAW_WEBHOOK_ENABLED=false
OPENCLAW_WEBHOOK_URL=http://127.0.0.1:10839/hooks/wake
OPENCLAW_WEBHOOK_TOKEN=

# 仅推送 >= 最小级别的报警: info / warning / critical
OPENCLAW_WEBHOOK_MIN_LEVEL=warning

# 请求参数（建议低思考以节省 token）
OPENCLAW_WEBHOOK_MODE=now
OPENCLAW_WEBHOOK_THINKING=low
OPENCLAW_WEBHOOK_CHANNEL=
OPENCLAW_WEBHOOK_SENDER_NAME=EcoMindAlarm

# 推送可靠性与去重
OPENCLAW_WEBHOOK_TIMEOUT_SECONDS=6
OPENCLAW_WEBHOOK_RETRY_TIMES=3
OPENCLAW_WEBHOOK_RETRY_BASE_DELAY_SECONDS=1
OPENCLAW_WEBHOOK_DEDUP_MINUTES=10
OPENCLAW_WEBHOOK_MAX_TEXT_LENGTH=1200
