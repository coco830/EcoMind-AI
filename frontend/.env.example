# 前端环境变量配置示例
# 复制此文件为 .env.development 或 .env.production 并填入实际值

# API 基础 URL
# 开发环境留空（使用 Vite 代理）
# 生产环境填入后端 API 地址
VITE_API_BASE_URL=

# 高德地图配置
# 请在高德开放平台申请 Web端(JS API) 的 Key
# https://console.amap.com/dev/key/app
VITE_AMAP_KEY=your_amap_key_here
VITE_AMAP_SECURITY_CODE=your_amap_security_code_here
