{
  "python.defaultInterpreterPath": "${workspaceFolder}/backend-cloudrun/.venv/Scripts/python.exe",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/backend-cloudrun"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticMode": "workspace",
  "python.analysis.exclude": [
    "**/.venv",
    "**/node_modules",
    "**/dist",
    "**/build"
  ],
  "typescript.tsdk": "frontend/node_modules/typescript/lib",
  "vue.server.includeLanguages": {
    "vue": "typescript"
  },
  "search.exclude": {
    "**/.venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/__pycache__": true,
    "**/.pytest_cache": true
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true
  }
}
